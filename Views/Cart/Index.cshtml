@model List<SHOPVN.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="page">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">🛒</div>
            <h3>Giỏ hàng trống</h3>
            <p>Hãy thêm sản phẩm vào giỏ hàng nhé!</p>
            <a asp-controller="Product" asp-action="Index" class="btn-primary">
                Tiếp tục mua sắm
            </a>
        </div>
    }
    else
    {
        <div class="cart-layout">
            <div>
                <h2 style="margin-bottom:20px">
                    Giỏ hàng (@Model.Count sản phẩm)
                </h2>

                @foreach (var item in Model)
                {
                    <div class="cart-item" id="cart-row-@item.Id">
                        <div class="ci-thumb">@item.Product.ImageEmoji</div>

                        <div class="ci-body">
                            <div class="ci-brand">@item.Product.Brand</div>
                            <div class="ci-name">@item.Product.Name</div>

                            <!-- qty -->
                            <div class="qty-control">
                                <button type="button"
                                        class="qty-btn"
                                        data-id="@item.Id"
                                        data-action="decrease">
                                    −
                                </button>

                                <span id="qty-@item.Id">@item.Quantity</span>

                                <button type="button"
                                        class="qty-btn"
                                        data-id="@item.Id"
                                        data-action="increase">
                                    +
                                </button>
                            </div>
                        </div>

                        <div style="text-align:right">
                            <div id="price-@item.Id">
                                @((item.Product.Price * item.Quantity).ToString("N0"))đ
                            </div>

                            <!-- remove -->
                            <form asp-action="Remove" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit">Xóa</button>
                            </form>
                        </div>
                    </div>
                }
            </div>

            <!-- summary -->
            <div class="order-summary">
                <div>
                    Tạm tính:
                    <span id="cart-total">@ViewBag.Total.ToString("N0")đ</span>
                </div>

                <div>
                    Tổng:
                    <span id="cart-total-main">@ViewBag.Total.ToString("N0")đ</span>
                </div>

                <a asp-controller="Order" asp-action="Checkout" class="btn-full">
                    Thanh toán
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
    @Html.AntiForgeryToken()

    <script>
        function getToken() {
            return document.querySelector('[name="__RequestVerificationToken"]').value;
        }

        function formatMoney(n) {
            return new Intl.NumberFormat('vi-VN').format(n) + 'đ';
        }

        document.querySelectorAll('.qty-btn').forEach(btn => {
            btn.addEventListener('click', function () {

                const id = parseInt(this.dataset.id);
                const action = this.dataset.action;

                fetch('/Cart/UpdateQty', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': getToken()
                    },
                    body: JSON.stringify({
                        cartItemId: id,
                        action: action
                    })
                })
                .then(r => r.json())
                .then(data => {
                    console.log(data);

                    if (!data.success) return;

                    // xóa nếu <=0
                    if (data.newQty <= 0) {
                        document.getElementById('cart-row-' + id)?.remove();
                        if (data.count === 0) location.reload();
                        return;
                    }

                    // update qty
                    document.getElementById('qty-' + id).textContent = data.newQty;

                    // update tổng
                    document.getElementById('cart-total').textContent = formatMoney(data.total);
                    document.getElementById('cart-total-main').textContent = formatMoney(data.total);

                    // update badge
                    const badge = document.querySelector('.cart-badge');
                    if (badge) badge.textContent = data.count;
                })
                .catch(err => console.error(err));
            });
        });
    </script>
}