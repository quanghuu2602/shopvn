@model List<SHOPVN.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="page">

    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">🛒</div>
            <h3>Giỏ hàng trống</h3>
            <p>Hãy thêm sản phẩm vào giỏ hàng nhé!</p>
            <a asp-controller="Product" asp-action="Index" class="btn-primary">
                Tiếp tục mua sắm
            </a>
        </div>
    }
    else
    {
        <div class="cart-layout">

            @* DANH SÁCH SẢN PHẨM *@
            <div>
                <div style="display:flex;justify-content:space-between;
                            align-items:center;margin-bottom:20px">
                    <h2 style="font-family:var(--font-display);font-size:26px">
                        Giỏ hàng (@Model.Count sản phẩm)
                    </h2>
                </div>

                @foreach (var item in Model)
                {
                    <div class="cart-item">
                        <div class="ci-thumb">@item.Product.ImageEmoji</div>
                        <div class="ci-body">
                            <div class="ci-brand">@item.Product.Brand</div>
                            <div class="ci-name">@item.Product.Name</div>

                            @* Nút tăng giảm số lượng *@
                            <div class="qty-control">
                                <button class="qty-btn"
                                        data-id="@item.Id"
                                        data-action="decrease">−</button>
                                <span class="qty-val">@item.Quantity</span>
                                <button class="qty-btn"
                                        data-id="@item.Id"
                                        data-action="increase">+</button>
                            </div>
                        </div>

                        <div style="text-align:right">
                            <div class="ci-price">
                                @((item.Product.Price * item.Quantity).ToString("N0"))đ
                            </div>
                            @* Nút xóa *@
                            <form asp-action="Remove" method="post" style="margin-top:8px">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="ci-remove">Xóa</button>
                            </form>
                        </div>
                    </div>
                }
            </div>

            @* TỔNG KẾT ĐƠN HÀNG *@
            <div class="order-summary">
                <div class="os-title">Tóm tắt đơn hàng</div>

                <div class="os-row">
                    <span>Tạm tính</span>
                    <span id="cart-total">@ViewBag.Total.ToString("N0")đ</span>
                </div>
                <div class="os-row">
                    <span>Phí vận chuyển</span>
                    <span style="color:var(--accent)">Miễn phí</span>
                </div>
                <div class="os-total">
                    <span>Tổng cộng</span>
                    <span class="os-total-val">@ViewBag.Total.ToString("N0")đ</span>
                </div>

                <a asp-controller="Order" asp-action="Checkout"
                   class="btn-full" style="display:block;text-align:center;margin-top:16px">
                    Thanh toán ngay →
                </a>

                <a asp-controller="Product" asp-action="Index"
                   style="display:block;text-align:center;font-size:13px;
                          color:var(--ink3);margin-top:12px">
                    ← Tiếp tục mua sắm
                </a>
            </div>

        </div>
    }

</div>

@section Scripts {
    @Html.AntiForgeryToken()
}