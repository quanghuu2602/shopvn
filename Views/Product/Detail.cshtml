@model SHOPVN.Models.Product
@{
    ViewData["Title"] = Model.Name;
}

<div class="page">

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;margin-bottom:48px">

        <div style="background:var(--surface2);border-radius:var(--radius-lg);
                    height:420px;display:flex;align-items:center;
                    justify-content:center;font-size:120px">
            @Model.ImageEmoji
        </div>

        <div>
            <div style="font-size:12px;color:var(--ink3);text-transform:uppercase;
                        letter-spacing:1px;margin-bottom:8px">
                @Model.Category?.Name
            </div>

            <div style="font-size:12px;color:var(--ink3);text-transform:uppercase;
                        letter-spacing:0.8px;margin-bottom:6px">
                @Model.Brand
            </div>

            <h1 style="font-family:var(--font-display);font-size:32px;
                       font-weight:500;margin-bottom:16px;line-height:1.2">
                @Model.Name
            </h1>

            <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:20px">
                <span style="font-size:28px;font-weight:500;color:var(--accent)">
                    @Model.Price.ToString("N0")đ
                </span>

                @if (Model.OriginalPrice.HasValue)
                {
                    <span style="font-size:18px;color:var(--ink3);text-decoration:line-through">
                        @Model.OriginalPrice.Value.ToString("N0")đ
                    </span>

                    var discount = (int)((1 - Model.Price / Model.OriginalPrice.Value) * 100);

                    <span style="background:#fdecea;color:var(--danger);
                                     font-size:13px;padding:3px 8px;border-radius:99px;font-weight:500">
                        -@discount%
                    </span>
                }
            </div>

            <p style="font-size:15px;color:var(--ink2);line-height:1.7;margin-bottom:24px">
                @Model.Description
            </p>

            <div style="font-size:13px;color:var(--ink3);margin-bottom:24px">
                @if (Model.Stock > 0)
                {
                    <span style="color:var(--accent)">✓ Còn hàng</span>
                    <span> (@Model.Stock sản phẩm)</span>
                }
                else
                {
                    <span style="color:var(--danger)">✕ Hết hàng</span>
                }
            </div>

            @if (User.Identity!.IsAuthenticated)
            {
                if (Model.Stock > 0)
                {
                    <div style="display:flex;gap:12px;align-items:center">

                        <!-- Tăng giảm -->
                        <div class="qty-control">
                            <button type="button" class="qty-btn" id="btn-minus">−</button>
                            <span class="qty-val" id="qty-val">1</span>
                            <button type="button" class="qty-btn" id="btn-plus">+</button>
                        </div>

                        <!-- NÚT ADD (FIX CHUẨN) -->
                        <button type="button"
                                class="btn-accent btn-add-cart"
                                data-id="@Model.Id"
                                style="flex:1">
                            Thêm vào giỏ hàng
                        </button>

                    </div>
                }
                else
                {
                    <button class="btn-full" disabled
                            style="background:var(--surface3);color:var(--ink3);cursor:not-allowed">
                        Hết hàng
                    </button>
                }
            }
            else
            {
                <a asp-controller="Account" asp-action="Login"
                   asp-route-returnUrl="@Context.Request.Path"
                   class="btn-accent" style="display:block;text-align:center">
                    Đăng nhập để mua hàng
                </a>
            }
        </div>
    </div>

</div>
@section Scripts {
    <script>
        let qty = 1;
        const maxStock = @Model.Stock;

        document.getElementById('btn-minus')
            ?.addEventListener('click', () => {
                if (qty > 1) {
                    qty--;
                    document.getElementById('qty-val').textContent = qty;
                }
            });

        document.getElementById('btn-plus')
            ?.addEventListener('click', () => {
                if (qty < maxStock) {
                    qty++;
                    document.getElementById('qty-val').textContent = qty;
                }
            });

        document.getElementById('btn-add-detail')
            ?.addEventListener('click', function () {
                const productId = parseInt(this.dataset.id);
                const btn = this;

                btn.textContent = 'Đang thêm...';
                btn.disabled = true;

                fetch('/Cart/Add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        productId: productId,
                        quantity: qty
                    })
                })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        window.showMsg('Đã thêm ' + qty + ' sản phẩm vào giỏ!');
                        window.updateBadge(data.count);
                    } else {
                        window.showMsg(data.message || 'Lỗi!', 'error');
                    }
                })
                .catch(() => window.showMsg('Lỗi!', 'error'))
                .finally(() => {
                    btn.textContent = 'Thêm vào giỏ hàng';
                    btn.disabled = false;
                });
            });
    </script>
}